{
  "name": "@agoric/xsnap",
  "version": "0.14.2",
  "description": "Snapshotting VM worker based on Moddable's XS Javascript engine",
  "author": "Agoric",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.js",
  "bin": {
    "ava-xs": "./src/ava-xs.js",
    "xsrepl": "./src/xsrepl"
  },
  "scripts": {
    "repl": "node src/xsrepl.js",
    "install:prebuilt": "node src/install-prebuilt.js",
    "build:latest": "node src/build.js --variant latest",
    "build:latest:env": "/bin/sh -c 'node src/build.js --variant latest --show-env > build.env.new && mv build.env.new build.env'",
    "build": "yarn install:prebuilt && yarn build:latest",
    "check-version": "/bin/sh -c 'if test \"${npm_package_version}\" != \"$(./scripts/get_xsnap_version.sh)\"; then echo \"xsnap version mismatch; expected '${npm_package_version}'\"; exit 1; fi'",
    "check-version:latest": "/bin/sh -c 'if test \"${npm_package_version}\" != \"$(./scripts/get_xsnap_version.sh latest)\"; then echo \"xsnap latest version mismatch; expected '${npm_package_version}'\"; exit 1; fi'",
    "postinstall": "npm run install:prebuilt && npm run build:latest",
    "clean": "rm -rf xsnap-native/xsnap/build latest/xsnap-native/xsnap/build",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs 'src/**/*.js' 'test/**/*.js' api.js",
    "lint:types": "yarn run -T tsc",
    "lint-fix": "yarn lint:eslint --fix",
    "test": "ava",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0"
  },
  "dependencies": {
    "@agoric/internal": "workspace:*",
    "@agoric/xsnap-lockdown": "workspace:*",
    "@endo/bundle-source": "^4.1.2",
    "@endo/errors": "^1.2.13",
    "@endo/eventual-send": "^1.3.4",
    "@endo/init": "^1.1.12",
    "@endo/netstring": "^1.0.18",
    "@endo/promise-kit": "^1.1.13",
    "@endo/stream": "^1.2.13",
    "@endo/stream-node": "^1.1.13",
    "glob": "^7.1.6",
    "tmp": "^0.2.1"
  },
  "devDependencies": {
    "@endo/base64": "^1.0.12",
    "@endo/nat": "^5.1.3",
    "ava": "^6.4.1",
    "c8": "^10.1.3",
    "execa": "^9.5.2",
    "ses": "^1.14.0"
  },
  "files": [
    "LICENSE*",
    "api.js",
    "build.env",
    "latest/moddable/modules/data/**",
    "latest/moddable/xs/includes/**",
    "latest/moddable/xs/makefiles/**",
    "latest/moddable/xs/sources/**",
    "latest/moddable/xs/platforms/*.h",
    "latest/moddable/xs/tools/fdlibm/**",
    "latest/xsnap-native/xsnap/makefiles/**",
    "latest/xsnap-native/xsnap/sources/**",
    "scripts/**",
    "src/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "ava": {
    "files": [
      "test/**/*.test.*"
    ],
    "require": [
      "@endo/init/debug.js"
    ],
    "timeout": "2m"
  },
  "typeCoverage": {
    "atLeast": 93.57
  },
  "engines": {
    "node": "^20.9 || ^22.11"
  }
}
